{
  "QuickBooks": {
    "AppId": "",
    "AppName": "AFC QuickBooks Agent",
    "CompanyFilePath": ""
  },
  "Security": {
    "ApiKey": "",
    "AllowedOrigins": [ "http://localhost:6000" ],
    "EnableAuthentication": true
  },
  "Agent": {
    "BackendBaseUrl": "https://localhost:5050",
    "AgentApiKey": "",
    "IdlePollSeconds": 30,
    "ErrorBackoffMinSeconds": 5,
    "ErrorBackoffMaxSeconds": 60
  },
  "Connection": {
    "TimeoutSeconds": 30,
    "MaxRetries": 3,
    "RetryDelaySeconds": 2
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
